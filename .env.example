# Environment Configuration Template - Copy as .env
# DO NOT COMMIT THIS FILE TO GIT

# ===== FLASK CONFIGURATION =====
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ===== DATABASE =====
DATABASE_URL=sqlite:///dual_sense_ai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dual_sense_ai
# For MySQL: mysql+pymysql://user:password@localhost:3306/dual_sense_ai

# ===== AZURE COGNITIVE SERVICES =====
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus

# ===== MODEL PATHS =====
SIGN_MODEL_PATH=models/fyp_30_word_kaggle_model.keras
ALPHABET_MODEL_PATH=models/alphabet_classifier.pkl
TRANSFER_MODEL_PATH=models/resnet50_asl.h5  # Optional

# ===== PERFORMANCE CONFIGURATION =====
CONFIDENCE_THRESHOLD=0.75
PREDICTION_FRAMES=60
MAX_QUEUE_SIZE=100
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/dual_sense_ai.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ===== REDIS CACHE =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== API RATE LIMITING =====
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=200/day,50/hour

# ===== CORS CONFIGURATION =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# ===== SECURITY =====
ENABLE_HTTPS=False
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# ===== MONITORING =====
SENTRY_DSN=
PROMETHEUS_PORT=9090

# ===== DEVELOPMENT/TESTING =====
TESTING=False
DEBUG_MODE=False
MOCK_SPEECH_SERVICE=False  # Use mock instead of Azure
